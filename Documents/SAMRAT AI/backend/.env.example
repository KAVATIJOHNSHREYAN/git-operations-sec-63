# ==========================================
# SAMRAT AI Backend - Environment Configuration
# ==========================================
# Copy this file to .env and fill in your actual values

# ==========================================
# Project Configuration
# ==========================================
PROJECT_NAME=SAMRAT AI
API_V1_STR=/api/v1
DEBUG=False
ENVIRONMENT=development

# ==========================================
# Database Configuration
# ==========================================
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
# SQLite: sqlite:///./app.db
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/samrat_ai

# ==========================================
# JWT & Security
# ==========================================
# Secret key for JWT token signing (generate a strong random string)
# Example: openssl rand -hex 32
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production-1234567890abcdef
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ==========================================
# AI/LLM API Keys
# ==========================================
# Google Generative AI (Gemini) - for text generation and embeddings
GOOGLE_GENAI_API_KEY=your_google_genai_api_key_here

# OpenAI - for DALL-E image generation and GPT models
OPENAI_API_KEY=sk-your_openai_api_key_here

# ==========================================
# Media Generation APIs
# ==========================================
# Replicate - for video generation and face swapping
REPLICATE_API_KEY=r8_your_replicate_api_key_here

# Eleven Labs - for voice/speech synthesis (optional)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Stability AI - for image generation alternatives (optional)
STABILITY_API_KEY=sk-your_stability_api_key_here

# ==========================================
# Vector Store Configuration
# ==========================================
# Directory for Chroma vector database storage (local)
CHROMA_DB_DIR=.chroma

# ==========================================
# CORS & Security
# ==========================================
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000,http://127.0.0.1:8000

# ==========================================
# Cache & Background Jobs
# ==========================================
# Redis connection for caching and Celery task broker
REDIS_URL=redis://localhost:6379/0

# ==========================================
# Celery Configuration (for async tasks)
# ==========================================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ==========================================
# Logging Configuration
# ==========================================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ==========================================
# Cloud Storage (optional)
# ==========================================
# Cloudinary for media hosting
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# AWS S3 for backup storage (optional)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=your_s3_bucket_name

# ==========================================
# Payment Processing (optional)
# ==========================================
STRIPE_SECRET_KEY=sk_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_your_stripe_publishable_key

# ==========================================
# Email/SMTP Configuration (optional)
# ==========================================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_FROM_EMAIL=noreply@samrat-ai.com
SMTP_FROM_NAME=SAMRAT AI

# ==========================================
# Analytics & Monitoring (optional)
# ==========================================
SENTRY_DSN=your_sentry_dsn_here

